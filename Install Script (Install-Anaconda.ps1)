#====================================================
# Install Script for Anaconda Python
# Version: 1.0.0
#====================================================


# Required Variables
$ScriptVersion = "1.0.0"
$AppName       = "Anaconda Python"
$SourceApp     = "Anaconda3-2024.02-1-Windows-x86_64.exe"
$InstallerType = "EXE"
$ArgumentList  = "/InstallationType=AllUsers /RegisterPython=0 /S /D=C:\ProgramData\Anaconda3"

$SourcePath = Join-Path $PSScriptRoot $SourceApp
$LogPath    = "C:\ProgramData\Logs\$($AppName.Replace(' ','_'))_Install.log"

#----------------------------------------------------
# Logging Function
#----------------------------------------------------
function Write-Log {
    param(
        [string]$Message,
        [ValidateSet("INFO","WARN","ERROR","SUCCESS")]
        [string]$Level = "INFO"
    )

    $TimeStamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$TimeStamp [$Level] $Message" | Out-File -FilePath $LogPath -Append -Encoding UTF8
}

#----------------------------------------------------
# Start Logging
#----------------------------------------------------
Write-Log "========== INSTALL START =========="
Write-Log "Script Version: $ScriptVersion"
Write-Log "App Name: $AppName"
Write-Log "Installer Path: $SourcePath"
Write-Log "Installer Type: $InstallerType"
Write-Log "Arguments: $ArgumentList"
Write-Log "Run Context: $([System.Security.Principal.WindowsIdentity]::GetCurrent().Name)"

#----------------------------------------------------
# Validate Installer
#----------------------------------------------------
if (!(Test-Path $SourcePath)) {
    Write-Log "Installer not found." "ERROR"
    exit 1
}

#----------------------------------------------------
# Execute Install
#----------------------------------------------------
try {
    Write-Log "Launching installer..."
    
    $Process = Start-Process -FilePath $SourcePath `
        -ArgumentList $ArgumentList `
        -Wait `
        -PassThru `
        -WindowStyle Hidden

    $ExitCode = $Process.ExitCode
    Write-Log "Installer exited with code: $ExitCode"

    if ($ExitCode -eq 0) {
        Write-Log "Installation completed successfully." "SUCCESS"
    }
    else {
        Write-Log "Installation failed." "ERROR"
        exit $ExitCode
    }
}
catch {
    Write-Log "Exception during install: $_" "ERROR"
    exit 1
}

#----------------------------------------------------
# Post Install Checks
#----------------------------------------------------
$PythonExe = "C:\ProgramData\Anaconda3\python.exe"

if (Test-Path $PythonExe) {
    Write-Log "Post-install validation passed: python.exe found." "SUCCESS"
}
else {
    Write-Log "Post-install validation failed: python.exe missing." "WARN"
}

Write-Log "========== INSTALL END =========="
exit 0
