# ==================================================
# Uninstall Script for Stunnel
# Version 1.0.0
# ==================================================

#Required Variables
$AppName = "Stunnel"
$SourceApp = "stunnel.msi"
$InstallerType = "MSI"
$ScriptVersion = "1.0.0"

$LogFile = "$PSScriptRoot\Logs\Uninstall.log"

function Write-Log {
    param($Message, $Severity="INFO", $LogFile)
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    Add-Content -Path $LogFile -Value "$timestamp [$Severity] $Message"
}

Write-Log "Starting uninstall script version $ScriptVersion" "INFO" $LogFile

try {
    # Example MSI uninstall via product code placeholder
    $ProductCode = "{PUT-STUNNEL-PRODUCT-CODE-HERE}"
    $ArgumentList = "/x $ProductCode /qn /norestart"

    Write-Log "Uninstall command: msiexec.exe $ArgumentList" "INFO" $LogFile

    $process = Start-Process "msiexec.exe" -ArgumentList $ArgumentList -Wait -PassThru -WindowStyle Hidden
    $exitCode = $process.ExitCode

    Write-Log "Uninstaller exit code: $exitCode" "INFO" $LogFile

    if ($exitCode -eq 0) {
        Write-Log "Uninstallation completed successfully" "SUCCESS" $LogFile
    }
    elseif ($exitCode -eq 3010) {
        Write-Log "Uninstallation successful but restart required (suppressed)" "WARN" $LogFile
    }
    else {
        Write-Log "Uninstallation failed with exit code $exitCode" "ERROR" $LogFile
    }
}
catch {
    Write-Log "Exception occurred: $_" "ERROR" $LogFile
    exit 1
}
